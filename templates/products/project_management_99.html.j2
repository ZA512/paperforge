<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <style>{{ inline_css|safe }}</style>
</head>
<body class="format-{{ options.page_format }} orientation-{{ options.orientation }}">
  <section class="page home-page" id="home">
    <div class="home-top">
      <div>
        <p class="kicker">{{ metadata.format }}</p>
        <h1>{{ title }}</h1>
        <p class="lead">{{ metadata.subtitle }}</p>
      </div>
      <nav class="home-nav">
        {% for link in nav %}<a href="#{{ link.target }}">{{ link.label }}</a>{% endfor %}
      </nav>
    </div>
    <div class="home-grid">
      <a href="#journal-1"><strong>Journal</strong><span>Capture rapide</span></a>
      <a href="#radar-1"><strong>Radar</strong><span>Relances W / B / D</span></a>
      <a href="#priorities"><strong>Priorites</strong><span>Sujets chauds</span></a>
      <a href="#index-1"><strong>Index</strong><span>Projets 01-{{ "%02d"|format(options.project_count) }}</span></a>
    </div>
    <div class="footer"><span>Accueil</span><span>{{ page_format.width_px }} x {{ page_format.height_px }} px</span></div>
  </section>

  <section class="page method-page" id="method">
    {% include "shared/topline.html.j2" %}
    <main class="page-body">
      <h2>Methode</h2>
      <p class="quiet">La nomenclature reste volontairement courte pour garder les pages utiles a l'ecriture.</p>
      <table class="table legend-table">
        <thead><tr><th>Symbole</th><th>Sens</th><th>Regle</th></tr></thead>
        <tbody>
          {% for item in symbols %}
          <tr><td>{{ item.symbol }}</td><td>{{ item.label }}</td><td>{{ item.rule }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </main>
    <div class="footer"><span>Methode</span><span>{{ title }}</span></div>
  </section>

  {% for page_no in journal_pages %}
  <section class="page table-page journal-page" id="journal-{{ page_no }}">
    {% include "shared/topline.html.j2" %}
    <main class="page-body">
      <div class="page-title-row">
        <h2>Journal {{ page_no }}/{{ options.journal_pages }}</h2>
        <div class="inline-fields"><span>Date</span><i></i><span>Focus</span><i></i></div>
      </div>
      <div class="table-fill journal-fill">
        <table class="table writing-table">
          <thead><tr><th style="width: 9%;">Type</th><th style="width: 14%;">Projet</th><th>Element</th><th style="width: 24%;">Suite</th></tr></thead>
          <tbody>{% for _ in range(row_counts.journal) %}<tr><td></td><td></td><td></td><td></td></tr>{% endfor %}</tbody>
        </table>
      </div>
    </main>
    <div class="footer"><span>Journal</span><span>{{ title }}</span></div>
  </section>
  {% endfor %}

  {% for page_no in radar_pages %}
  <section class="page table-page radar-page" id="radar-{{ page_no }}">
    {% include "shared/topline.html.j2" %}
    <main class="page-body">
      <div class="page-title-row"><h2>Radar {{ page_no }}/{{ options.radar_pages }}</h2><p>W attente · B blocage · D decision</p></div>
      <div class="table-fill radar-fill">
        <table class="table writing-table">
          <thead><tr><th style="width: 8%;">Type</th><th style="width: 12%;">Date</th><th style="width: 14%;">Projet</th><th>Sujet</th><th style="width: 22%;">Attendu</th><th style="width: 18%;">Relance</th></tr></thead>
          <tbody>{% for _ in range(row_counts.radar) %}<tr><td></td><td></td><td></td><td></td><td></td><td></td></tr>{% endfor %}</tbody>
        </table>
      </div>
    </main>
    <div class="footer"><span>Radar</span><span>{{ title }}</span></div>
  </section>
  {% endfor %}

  <section class="page table-page priorities-page" id="priorities">
    {% include "shared/topline.html.j2" %}
    <main class="page-body">
      <div class="page-title-row"><h2>Priorites</h2><p>Sujets chauds de la semaine ou du mois</p></div>
      <div class="table-fill priorities-fill">
        <table class="table writing-table">
          <thead><tr><th style="width: 18%;">Projet</th><th>Sujet</th><th style="width: 24%;">Prochaine action</th><th style="width: 14%;">Echeance</th></tr></thead>
          <tbody>{% for _ in range(row_counts.priorities) %}<tr><td></td><td></td><td></td><td></td></tr>{% endfor %}</tbody>
        </table>
      </div>
    </main>
    <div class="footer"><span>Priorites</span><span>{{ title }}</span></div>
  </section>

  {% for group in index_groups %}
  <section class="page table-page index-page" id="index-{{ loop.index }}">
    {% include "shared/topline.html.j2" %}
    <main class="page-body">
      <div class="page-title-row"><h2>Index {{ group[0].code }}-{{ group[-1].code }}</h2><p>N / Projet / Etat</p></div>
      <div class="table-fill index-fill">
        <table class="table index-table">
          <thead><tr><th style="width: 10%;">N</th><th>Projet</th><th style="width: 22%;">Etat</th></tr></thead>
          <tbody>
            {% for project in group %}
            <tr><td><a class="index-number" href="#project-{{ project.code }}-summary">{{ project.code }}</a></td><td></td><td></td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </main>
    <div class="footer"><span>Index</span><span>{{ title }}</span></div>
  </section>
  {% endfor %}

  {% for project in projects %}
  <section class="page project-summary" id="project-{{ project.code }}-summary">
    {% include "shared/topline.html.j2" %}
    <main class="page-body">
      <div class="page-title-row">
        <h2>Projet {{ project.code }}</h2>
        <div class="page-actions">
          {% if not loop.first %}<a href="#project-{{ "%02d"|format(project.number - 1) }}-summary">&lt;</a>{% endif %}
          {% if options.pages_per_project >= 2 %}<a href="#project-{{ project.code }}-actions">Actions</a>{% endif %}
          {% if not loop.last %}<a href="#project-{{ "%02d"|format(project.number + 1) }}-summary">&gt;</a>{% endif %}
        </div>
      </div>
      <div class="project-fields">
        <label>Nom <i></i></label>
      </div>
      <div class="summary-grid">
        <div><h3>Objectif</h3><div class="note-lines"></div></div>
      </div>
      <h3>Actions</h3>
      <div class="table-fill open-points-fill">
        <table class="table writing-table project-writing-table">
          <thead><tr><th style="width: 16%;">Date</th><th>Actions</th></tr></thead>
          <tbody>{% for _ in range(row_counts.open_points) %}<tr><td></td><td></td></tr>{% endfor %}</tbody>
        </table>
      </div>
    </main>
    <div class="footer"><span>Projet {{ project.code }} · synthese</span><span>{{ title }}</span></div>
  </section>

  {% if options.pages_per_project >= 2 %}
  <section class="page table-page actions-page" id="project-{{ project.code }}-actions">
    {% include "shared/topline.html.j2" %}
    <main class="page-body">
      <div class="page-title-row">
        <h2>Projet {{ project.code }} · Actions</h2>
        <div class="page-actions">
          <a href="#project-{{ project.code }}-summary">Synthese</a>
          {% if options.pages_per_project >= 3 %}<a href="#project-{{ project.code }}-extra-3">Notes</a>{% endif %}
        </div>
      </div>
      <div class="table-fill actions-fill">
        <table class="table writing-table project-writing-table">
          <thead><tr><th style="width: 16%;">Date</th><th>Actions</th></tr></thead>
          <tbody>{% for _ in range(row_counts.actions) %}<tr><td></td><td></td></tr>{% endfor %}</tbody>
        </table>
      </div>
    </main>
    <div class="footer"><span>Projet {{ project.code }} · actions</span><span>{{ title }}</span></div>
  </section>
  {% endif %}

  {% for page_no in extra_project_pages %}
  <section class="page note-page" id="project-{{ project.code }}-extra-{{ page_no }}">
    {% include "shared/topline.html.j2" %}
    <main class="page-body">
      <div class="page-title-row">
        <h2>Projet {{ project.code }} · notes {{ page_no }}/{{ options.pages_per_project }}</h2>
        <div class="page-actions">
          <a href="#project-{{ project.code }}-summary">Synthese</a>
          {% if page_no > 3 %}<a href="#project-{{ project.code }}-extra-{{ page_no - 1 }}">&lt;</a>{% else %}<a href="#project-{{ project.code }}-actions">&lt;</a>{% endif %}
          {% if page_no < options.pages_per_project %}<a href="#project-{{ project.code }}-extra-{{ page_no + 1 }}">&gt;</a>{% endif %}
        </div>
      </div>
      <div class="note-fill"></div>
    </main>
    <div class="footer"><span>Projet {{ project.code }} · notes</span><span>{{ title }}</span></div>
  </section>
  {% endfor %}
  {% endfor %}
</body>
</html>
