<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Paperforge</title>
  <link rel="stylesheet" href="/static/app.css">
</head>
<body>
  <main class="shell">
    <header class="masthead">
      <div>
        <p class="eyebrow">Paperforge</p>
        <h1>Atelier de carnets PDF</h1>
      </div>
      <div class="status-strip">
        <span>HTML/CSS</span>
        <span>Jinja2</span>
        <span>WeasyPrint</span>
      </div>
    </header>

    <form class="workspace" method="post" action="/generate">
      <section class="pane product-pane" aria-labelledby="product-title">
        <div class="pane-head">
          <h2 id="product-title">Produit</h2>
          <span class="count">{{ products|length }}</span>
        </div>
        <div class="choice-list">
          {% for product in products %}
          {% set selected = values.get('product', default_product) == product.slug %}
          <label class="choice{% if selected %} is-selected{% endif %}">
            <input type="radio" name="product" value="{{ product.slug }}" {% if selected %}checked{% endif %}>
            <span>
              <strong>{{ product.label }}</strong>
              <small>{{ product.slug }}</small>
            </span>
          </label>
          {% endfor %}
        </div>
      </section>

      <section class="pane settings-pane" aria-labelledby="settings-title">
        <div class="pane-head">
          <h2 id="settings-title">Parametrage</h2>
          <span class="count">V1</span>
        </div>
        <div class="field-grid">
          <label class="field wide">
            <span>Titre</span>
            <input name="title" value="{{ values.get('title', 'Carnet de pilotage projets') }}">
          </label>
          <label class="field wide">
            <span>Sous-titre</span>
            <input name="subtitle" value="{{ values.get('subtitle', 'Capture rapide, radar de relance, index hyperlie et 99 projets en deux pages.') }}">
          </label>

          {% for product in products %}
            {% for option in product.options %}
            {% if option.key not in ('cover_style', 'cover_color') %}
            <label class="field">
              <span>{{ option.label }}</span>
              {% if option.option_type == 'select' %}
              <select name="{{ option.key }}">
                {% for choice in option.choices %}
                <option value="{{ choice }}" {% if values.get(option.key, option.default) == choice %}selected{% endif %}>
                  {{ choice_labels.get(option.key, {}).get(choice, choice) }}
                </option>
                {% endfor %}
              </select>
              {% else %}
              <input
                name="{{ option.key }}"
                type="{% if option.option_type == 'number' %}number{% else %}text{% endif %}"
                value="{{ values.get(option.key, option.default) }}"
                {% if option.min_value is not none %}min="{{ option.min_value }}"{% endif %}
                {% if option.max_value is not none %}max="{{ option.max_value }}"{% endif %}
              >
              {% endif %}
            </label>
            {% endif %}
            {% endfor %}
          {% endfor %}
        </div>
      </section>

      <section class="pane theme-pane" aria-labelledby="theme-title">
        <div class="pane-head">
          <h2 id="theme-title">Theme</h2>
          <span class="count">{{ themes|length }}</span>
        </div>
        <div class="theme-list">
          {% for theme in themes %}
          {% set selected = values.get('theme', default_theme) == theme.slug %}
          <label class="theme-choice{% if selected %} is-selected{% endif %}">
            <input type="radio" name="theme" value="{{ theme.slug }}" {% if selected %}checked{% endif %}>
            <span class="theme-preview {{ theme.preview_class }}" aria-hidden="true">
              <span class="preview-top"></span>
              <span class="preview-head"></span>
              <span class="preview-nav"></span>
              <span class="preview-title"></span>
              <span class="preview-name"></span>
              <span class="preview-objective"></span>
              <span class="preview-table">
                <i></i><i></i><i></i><i></i><i></i><i></i>
              </span>
            </span>
            <span class="sr-only">{{ theme.label }}</span>
          </label>
          {% endfor %}
        </div>

        <div class="cover-box">
          <div class="pane-head compact-head">
            <h2>Couverture</h2>
            <span class="count">{{ cover_styles|length }}</span>
          </div>
          <div class="cover-controls">
            <label class="field">
              <span>Couleur</span>
              <input class="color-input" name="cover_color" type="color" value="{{ values.get('cover_color', '#176f75') }}">
            </label>
            <div class="cover-list">
              {% for cover_slug, cover_label in cover_styles.items() %}
              {% set selected = values.get('cover_style', 'solid') == cover_slug %}
              <label class="cover-choice cover-{{ cover_slug }}{% if selected %} is-selected{% endif %}">
                <input type="radio" name="cover_style" value="{{ cover_slug }}" {% if selected %}checked{% endif %}>
                <span class="cover-preview" aria-hidden="true"></span>
                <strong>{{ cover_label }}</strong>
              </label>
              {% endfor %}
            </div>
          </div>
        </div>

        <div class="export-box">
          <h2>Export</h2>
          <div class="actions">
            <button name="action" value="html" type="submit">Generer HTML</button>
            <button name="action" value="pdf" type="submit">Generer PDF</button>
            <button name="action" value="command" type="submit" class="ghost">Commande</button>
          </div>
        </div>

        {% if result %}
        <aside class="result result-{{ result.status }}">
          <strong>{{ result.message }}</strong>
          {% if result.html_url %}<a href="{{ result.html_url }}" target="_blank">Ouvrir HTML</a>{% endif %}
          {% if result.pdf_url %}<a href="{{ result.pdf_url }}" target="_blank">Ouvrir PDF</a>{% endif %}
          <code>{{ result.command }}</code>
        </aside>
        {% endif %}
      </section>
    </form>
  </main>
  <script>
    const coverColor = document.querySelector('input[name="cover_color"]');
    const syncCoverColor = () => {
      if (coverColor) document.documentElement.style.setProperty('--cover-choice-color', coverColor.value);
    };
    syncCoverColor();
    coverColor?.addEventListener('input', syncCoverColor);

    document.querySelectorAll('.theme-choice input, .cover-choice input').forEach((input) => {
      input.addEventListener('change', () => {
        document.querySelectorAll(`input[name="${input.name}"]`).forEach((peer) => {
          peer.closest('label').classList.toggle('is-selected', peer.checked);
        });
      });
    });
  </script>
</body>
</html>
